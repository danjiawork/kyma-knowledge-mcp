# Path to a locally built index directory or downloaded .tar.gz archive.
# If not set, the server auto-downloads the pre-built index on first run.
# LOCAL_INDEX_PATH=/tmp/kmc-index

# Override the embedding model used for queries (normally read from meta.json).
# Only needed if you built the index with a non-default model.
# LOCAL_EMBED_MODEL_OVERRIDE=BAAI/bge-small-en-v1.5

# Logging level. Use DEBUG for verbose output during development.
# LOG_LEVEL=INFO
