# Path to a locally built index directory or downloaded .tar.gz archive.
# If not set, the server auto-downloads the pre-built index on first run.
# LOCAL_INDEX_PATH=/tmp/kmc-index

# Override the embedding model used for queries (normally read from meta.json).
# Only needed if you built the index with a non-default model.
# LOCAL_EMBED_MODEL_OVERRIDE=BAAI/bge-small-en-v1.5

# Default number of results returned by user-facing search tools.
# DEFAULT_TOP_K=10

# Cross-encoder reranker model (enabled by default, Apache 2.0, ~30 MB).
# The model is downloaded once on first use and cached in ~/.kyma-knowledge-mcp/reranker/.
# Set to empty string to disable reranking (pure vector search, faster).
# RERANKER_MODEL=ms-marco-TinyBERT-L-2-v2
# Disable reranking:
# RERANKER_MODEL=
# Higher quality, ~130 MB, ~4-5× slower:
# RERANKER_MODEL=ms-marco-MiniLM-L-12-v2

# Number of vector-search candidates to fetch per final result (default: 3).
# Only used when RERANKER_MODEL is set.  fetch_n = top_k × RERANKER_FETCH_MULTIPLIER
# RERANKER_FETCH_MULTIPLIER=3

# Logging level. Use DEBUG for verbose output during development.
# LOG_LEVEL=INFO
